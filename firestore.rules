rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Fields: name (string), bi (string), nif (string), inss (string), role (string), 
    //         department (string), baseSalary (number), admissionDate (string), 
    //         contractType (string), status (string)
    //
    // Collection: attendance
    // Fields: employeeId (string), date (string), status (string), overtimeHours (number), notes (string)
    //
    // Collection: payrolls
    // Fields: employeeId (string), month (number), year (number), baseSalary (number), 
    //         inssWorker (number), inssCompany (number), irt (number), netSalary (number), status (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "monteirogarcia77@gmail.com");
    }

    function isValidEmployee(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.bi is string && data.bi.size() > 0 &&
             data.nif is string && data.nif.size() > 0 &&
             data.baseSalary is number && data.baseSalary >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidEmployee(request.resource.data);
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /payrolls/{payrollId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /vacations/{vacationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /performance/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /career/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
